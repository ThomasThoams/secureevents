{% extends 'base.html.twig' %}

{% block title %}Participants — {{ event.titre }}{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_index') }}">Administration</a></li>
            <li class="breadcrumb-item active">Participants</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2>Participants : {{ event.titre }}</h2>
            <p class="text-muted mb-0">
                📅 {{ event.dateDebut|date('d/m/Y à H:i') }} — 📍 {{ event.lieu }}<br>
                {{ reservations|length }} / {{ event.capaciteMax }} inscrits
            </p>
        </div>
        <a href="{{ path('app_admin_index') }}" class="btn btn-secondary">Retour</a>
    </div>

    {% if reservations is empty %}
        <div class="alert alert-info">Aucun inscrit pour cet événement.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Prénom</th>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Inscrit le</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in reservations %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>{{ reservation.user.prenom }}</td>
                            <td>{{ reservation.user.nom }}</td>
                            <td>{{ reservation.user.email }}</td>
                            <td>{{ reservation.createdAt|date('d/m/Y à H:i') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
