{% extends 'base.html.twig' %}

{% block title %}Connexion — SecurEvent{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-5">
            <h2 class="mb-4">Connexion</h2>

            {% if error %}
                <div class="alert alert-danger">Identifiants invalides.</div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="post" action="{{ path('app_login') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" id="email" name="_username" class="form-control"
                                   value="{{ last_username }}" autocomplete="email" required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Mot de passe</label>
                            <input type="password" id="password" name="_password" class="form-control"
                                   autocomplete="current-password" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Se connecter</button>
                    </form>
                </div>
            </div>

            <p class="text-center mt-3">
                Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a>
            </p>
        </div>
    </div>
{% endblock %}
