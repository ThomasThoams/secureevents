{% extends 'base.html.twig' %}

{% block title %}Inscription — SecurEvent{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4">Créer un compte</h2>

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(registrationForm, {attr: {novalidate: 'novalidate'}}) }}

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(registrationForm.prenom) }}
                            {{ form_widget(registrationForm.prenom, {attr: {class: 'form-control' ~ (registrationForm.prenom.vars.errors|length ? ' is-invalid' : '')}}) }}
                            {{ form_errors(registrationForm.prenom) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_label(registrationForm.nom) }}
                            {{ form_widget(registrationForm.nom, {attr: {class: 'form-control' ~ (registrationForm.nom.vars.errors|length ? ' is-invalid' : '')}}) }}
                            {{ form_errors(registrationForm.nom) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.email) }}
                        {{ form_widget(registrationForm.email, {attr: {class: 'form-control' ~ (registrationForm.email.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.first) }}
                        {{ form_widget(registrationForm.plainPassword.first, {attr: {class: 'form-control' ~ (registrationForm.plainPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.second) }}
                        {{ form_widget(registrationForm.plainPassword.second, {attr: {class: 'form-control' ~ (registrationForm.plainPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Créer mon compte</button>

                    {{ form_end(registrationForm) }}
                </div>
            </div>

            <p class="text-center mt-3">
                Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
            </p>
        </div>
    </div>
{% endblock %}
