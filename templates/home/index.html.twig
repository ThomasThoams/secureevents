{% extends 'base.html.twig' %}

{% block title %}SecurEvent — Catalogue{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">Événements à venir</h1>
            <p class="text-muted">Conférences, CTF et workshops autour de la cybersécurité.</p>
        </div>
    </div>

    {% if events is empty %}
        <div class="alert alert-info">Aucun événement à venir pour le moment.</div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for event in events %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">{{ event.titre }}</h5>
                            <p class="card-text text-muted small">
                                📅 {{ event.dateDebut|date('d/m/Y à H:i') }}<br>
                                📍 {{ event.lieu }}<br>
                                👥 {{ event.capaciteMax - event.reservations|length }} place(s) restante(s)
                            </p>
                            <p class="card-text">{{ event.description|slice(0, 120) }}{% if event.description|length > 120 %}…{% endif %}</p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-primary btn-sm">
                                Voir les détails
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
